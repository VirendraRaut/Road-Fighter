{
  "version": 2,
  "routes": [
    {
      "src": "/audioManager.js",
      "dest": "/audioManager.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/assets.js",
      "dest": "/assets.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/game.js",
      "dest": "/game.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/ui.js",
      "dest": "/ui.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/script.js",
      "dest": "/script.js",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/style.css",
      "dest": "/style.css",
      "headers": {
        "Content-Type": "text/css"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
